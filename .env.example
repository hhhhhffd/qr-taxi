# ==========================================
# POSTGRESQL DATABASE
# ==========================================
POSTGRES_USER=postgres
# Сгенерируй надежный пароль в терминале: openssl rand -base64 32
POSTGRES_PASSWORD=secure_postgres_password
POSTGRES_DB=aparu
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ==========================================
# REDIS CACHE
# ==========================================
# Сгенерируй надежный пароль в терминале: openssl rand -base64 32
REDIS_PASSWORD=secure_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ==========================================
# TELEGRAM BOT
# ==========================================
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ
BOT_USERNAME=aparu_bot
# Секретная строка для защиты вебхуков: openssl rand -hex 32
WEBHOOK_SECRET=your_secure_webhook_secret

# ==========================================
# APARU API
# ==========================================
APARU_API_KEY=your_aparu_api_key
APARU_API_URL=http://testtaxi3.aparu.kz

# ==========================================
# SECURITY & JWT
# ==========================================
# Главный секрет для подписи токенов: openssl rand -hex 32
JWT_SECRET=your_secure_jwt_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=7

# ==========================================
# INFRASTRUCTURE & SETTINGS
# ==========================================
DOMAIN=your_domain.com
DEBUG=True
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ==========================================
# METABASE EMBED (ADMIN ANALYTICS)
# ==========================================
# Public Metabase URL available to browser.
# Recommended same-origin proxy path via nginx (works for localhost and domain deployments).
METABASE_SITE_URL=/metabase
# Public absolute URL of Metabase itself (used by Metabase for embed/static asset links).
# For production set your real domain, e.g. https://your-domain.com/metabase
METABASE_PUBLIC_SITE_URL=http://localhost/metabase
# Admin > Settings > Embedding in Metabase
METABASE_EMBED_SECRET=your_metabase_embedding_secret
# ID of dashboard to embed into /admin/heatmap
METABASE_DASHBOARD_ID=1
# Signed URL lifetime in minutes
METABASE_EMBED_TTL_MINUTES=60
